{
  // Enable format on save; Prisma extension will register its formatter
  "editor.formatOnSave": true,
  "[prisma]": {
    "editor.formatOnSave": true,
    "editor.suggest.snippetsPreventQuickSuggestions": false
  },
  // Associate .prisma files with the Prisma language mode explicitly
  "files.associations": {
    "*.prisma": "prisma"
  },
  // Ensure Copilot provides inline suggestions in Prisma files
  "github.copilot.enable": {
    "*": true,
    "prisma": true
  },
  // Enable inline suggestions globally (utilized by Copilot)
  "editor.inlineSuggest.enabled": true,
  // Optional: Improve quick suggestions timing
  "editor.quickSuggestionsDelay": 50
}