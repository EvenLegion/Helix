{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "db:generate":{
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:deploy": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["GUILD_ID", "BETTER_AUTH_SECRET", "BASE_URL", "AUTH_DISCORD_ID", "AUTH_DISCORD_SECRET", "NODE_ENV", "DATABASE_URL", "DISCORD_TOKEN"]
    },
    "arbiter#build": {
      "dependsOn": ["^build", "^db:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"],
      "env": ["GUILD_ID", "BETTER_AUTH_SECRET", "BASE_URL", "AUTH_DISCORD_ID", "AUTH_DISCORD_SECRET", "NODE_ENV", "DATABASE_URL", "DISCORD_TOKEN"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "dependsOn": ["^db:generate"],
      "cache": false,
      "persistent": true,
      "env": ["GUILD_ID", "BETTER_AUTH_SECRET", "BASE_URL", "AUTH_DISCORD_ID", "AUTH_DISCORD_SECRET", "NODE_ENV", "DATABASE_URL", "DISCORD_TOKEN"]
    }
  }
}
