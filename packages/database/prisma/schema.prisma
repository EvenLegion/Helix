generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["arbiter", "nexus"]
}

model User {
  id                 String              @id
  username           String?
  nickname           String?
  preferredName      String?
  name               String?
  email              String?
  emailVerified      Boolean?
  image              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  Merit              Merit?
  nameChangeRequests NameChangeRequest[]
  accounts           Account[]
  sessions           Session[]

  @@map("user")
  @@schema("nexus")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
  @@schema("nexus")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
  @@schema("nexus")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
  @@schema("nexus")
}

model NameChangeRequest {
  id            Int      @id @default(autoincrement())
  userId        String
  currentName   String
  requestedName String
  reason        String
  denyReason    String?
  approved      Boolean  @default(false)
  approvedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("nameChangeRequest")
  @@schema("arbiter")
}

model Merit {
  userID          String    @id @db.VarChar(19)
  merits          Int
  description     String    @db.VarChar(255)
  additionalNotes String    @db.VarChar(255)
  awardedBy       String
  createdAt       DateTime  @default(now())
  typeId          Int
  updatedAt       DateTime  @updatedAt
  meritType       MeritType @relation(fields: [typeId], references: [id])
  user            User      @relation(fields: [userID], references: [id])

  @@map("merit")
  @@schema("arbiter")
}

model MeritType {
  id            Int            @id
  name          String         @db.VarChar(100)
  description   String         @db.VarChar(255)
  value         Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  eventSessions EventSession[]
  merit         Merit[]

  @@map("meritType")
  @@schema("arbiter")
}

/// Event session within a guild voice channel
model EventSession {
  id               Int                       @id @default(autoincrement())
  /// If set, this session is part of a group whose root session has this id
  rootSessionId    Int?
  guildId          String
  channelId        String
  /// True if the voice/stage channel was created by the bot
  createdByBot     Boolean                   @default(false)
  startedBy        String
  startedAt        DateTime                  @default(now())
  endedAt          DateTime?
  status           String                    @default("ACTIVE") @db.VarChar(16)
  meritTypeId      Int?
  /// Optional custom description to use when awarding merits from this event
  awardDescription String?                   @db.VarChar(255)
  meritType        MeritType?                @relation(fields: [meritTypeId], references: [id])
  root             EventSession?             @relation("EventSessionGroup", fields: [rootSessionId], references: [id])
  children         EventSession[]            @relation("EventSessionGroup")
  participants     EventSessionParticipant[]

  @@index([guildId, channelId, status])
  @@index([rootSessionId, status])
  @@map("eventSession")
  @@schema("arbiter")
}

/// Aggregate participation per user for an event session
model EventSessionParticipant {
  id                   Int          @id @default(autoincrement())
  eventSessionId       Int
  userId               String
  totalSecondsPresent  Int          @default(0)
  totalSecondsSpeaking Int          @default(0)
  lastJoinAt           DateTime?
  lastSpeakAt          DateTime?
  updatedAt            DateTime     @updatedAt
  session              EventSession @relation(fields: [eventSessionId], references: [id], onDelete: Cascade)

  @@unique([eventSessionId, userId])
  @@map("eventSessionParticipant")
  @@schema("arbiter")
}

model Event {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  description String    @db.VarChar(255)
  createdAt   DateTime  @default(now())
  eventDate   DateTime
  typeId      Int
  updatedAt   DateTime  @updatedAt
  eventType   EventType @relation(fields: [typeId], references: [id])

  @@map("event")
  @@schema("arbiter")
}

model EventType {
  id          Int      @id
  name        String   @db.VarChar(100)
  description String   @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Event       Event[]

  @@map("eventType")
  @@schema("arbiter")
}

/// Divisions for display and rules
model Division {
  id             Int                  @id @default(autoincrement())
  code           String               @unique
  name           String
  kind           String
  nicknamePrefix String?
  showRank       Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  memberships    DivisionMembership[]

  @@map("division")
  @@schema("arbiter")
}

/// Global cumulative merits required for each level (1..40)
model RankLevel {
  level            Int @id
  cumulativeMerits Int

  @@map("rankLevel")
  @@schema("arbiter")
}

/// Per-user diagnostics and tracking for nickname decoration
model DivisionMembership {
  id                       Int       @id @default(autoincrement())
  userID                   String
  divisionId               Int
  lastComputedLevel        Int?
  lastComputedAt           DateTime?
  lastAppliedNicknameLevel Int?
  lastNicknameUpdatedAt    DateTime?
  nicknameSyncStatus       String?
  notes                    String?
  division                 Division  @relation(fields: [divisionId], references: [id])

  @@unique([userID, divisionId])
  @@index([userID])
  @@map("divisionMembership")
  @@schema("arbiter")
}
