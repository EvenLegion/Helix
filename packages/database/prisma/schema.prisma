// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["arbiter", "nexus"]
}

model User {
  id                 String              @id
  username           String?
  nickname           String?
  name               String?
  email              String?
  emailVerified      Boolean?
  image              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  Merit              Merit[]
  nameChangeRequests NameChangeRequest[]
  accounts           Account[]
  sessions           Session[]

  @@map("user")
  @@schema("nexus")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
  @@schema("nexus")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
  @@schema("nexus")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
  @@schema("nexus")
}

model NameChangeRequest {
  id            Int      @id @default(autoincrement())
  userId        String   @db.Char(19)
  currentName   String
  requestedName String
  reason        String
  denyReason    String?
  approved      Boolean  @default(false)
  approvedBy    String?  @db.Char(19)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("name_change_request")
  @@schema("arbiter")
}

model Merit {
  userID          String    @id @db.Char(19)
  merits          Int
  description     String    @db.VarChar(255)
  additonal_notes String    @db.VarChar(255)
  awarded_by      String    @db.Char(19)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  type_id         Int
  merit_type      MeritType @relation(fields: [type_id], references: [id])
  user            User      @relation(fields: [userID], references: [id])

  @@map("merit")
  @@schema("arbiter")
}

model MeritType {
  id          Int      @id
  name        String   @db.VarChar(100)
  description String   @db.VarChar(255)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  merit       Merit[]

  @@map("merit_type")
  @@schema("arbiter")
}

/// Event session within a guild voice channel
model EventSession {
  id           Int                       @id @default(autoincrement())
  guildId      String                    @db.Char(19)
  channelId    String                    @db.Char(19)
  startedBy    String                    @db.Char(19)
  startedAt    DateTime                  @default(now())
  endedAt      DateTime?
  status       String                    @default("ACTIVE") @db.VarChar(16)
  participants EventSessionParticipant[]

  @@index([guildId, channelId, status])
  @@map("event_session")
  @@schema("arbiter")
}

// Status values: ACTIVE | ENDED

/// Aggregate participation per user for an event session
model EventSessionParticipant {
  id                   Int          @id @default(autoincrement())
  eventSessionId       Int
  userId               String       @db.Char(19)
  totalSecondsPresent  Int          @default(0)
  totalSecondsSpeaking Int          @default(0)
  lastJoinAt           DateTime?
  lastSpeakAt          DateTime?
  updatedAt            DateTime     @updatedAt
  session              EventSession @relation(fields: [eventSessionId], references: [id], onDelete: Cascade)

  @@unique([eventSessionId, userId])
  @@map("event_session_participant")
  @@schema("arbiter")
}

model Event {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  description String    @db.VarChar(255)
  event_date  DateTime
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  type_id     Int
  event_type  EventType @relation(fields: [type_id], references: [id])

  @@map("event")
  @@schema("arbiter")
}

model EventType {
  id          Int      @id
  name        String   @db.VarChar(100)
  description String   @db.VarChar(255)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  Event       Event[]

  @@map("event_type")
  @@schema("arbiter")
}
