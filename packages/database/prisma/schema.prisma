// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
    output   = "./../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
    schemas  = ["arbiter", "nexus"]
}

model User {
    id                      String                   @id
    username                String?
    nickname                String?
    name                    String?
    email                   String?
    emailVerified           Boolean?
    image                   String?
    createdAt               DateTime                 @default(now())
    updatedAt               DateTime                 @updatedAt
    role                    String?
    banned                  Boolean?                 @default(false)
    banReason               String?
    banExpires              DateTime?
    Merit                   Merit[]
    nameChangeRequests      NameChangeRequest[]
    accounts                Account[]
    sessions                Session[]
    Member                  Member[]
    Invitation              Invitation[]
    auditLogs               AuditLog[]
    recruitmentApplications RecruitmentApplication[] @relation("ApplicantUser")
    reviewedApplications    RecruitmentApplication[] @relation("ReviewerUser")

    @@map("user")
    @@schema("nexus")
}

model Session {
    id                   String   @id
    expiresAt            DateTime
    token                String   @unique
    createdAt            DateTime @default(now())
    updatedAt            DateTime @updatedAt
    ipAddress            String?
    userAgent            String?
    userId               String
    activeOrganizationId String?
    activeTeamId         String?
    impersonatedBy       String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("session")
    @@schema("nexus")
}

model Account {
    id                    String    @id
    accountId             String
    providerId            String
    userId                String
    accessToken           String?
    refreshToken          String?
    idToken               String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt
    user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("account")
    @@schema("nexus")
}

model Verification {
    id         String    @id
    identifier String
    value      String
    expiresAt  DateTime
    createdAt  DateTime? @default(now())
    updatedAt  DateTime? @updatedAt

    @@map("verification")
    @@schema("nexus")
}

model NameChangeRequest {
    id            Int      @id @default(autoincrement())
    userId        String
    currentName   String
    requestedName String
    reason        String
    denyReason    String?
    approved      Boolean  @default(false)
    approvedBy    String?
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("name_change_request")
    @@schema("arbiter")
}

model Merit {
    userID          String    @id
    merits          Int
    description     String    @db.VarChar(255)
    additonal_notes String    @db.VarChar(255)
    awarded_by      String
    created_at      DateTime  @default(now())
    updated_at      DateTime  @updatedAt
    type_id         Int
    merit_type      MeritType @relation(fields: [type_id], references: [id])
    user            User      @relation(fields: [userID], references: [id])

    @@map("merit")
    @@schema("arbiter")
}

model MeritType {
    id          Int      @id
    name        String   @db.VarChar(100)
    description String   @db.VarChar(255)
    created_at  DateTime @default(now())
    updated_at  DateTime @updatedAt
    merit       Merit[]

    @@map("merit_type")
    @@schema("arbiter")
}

model Organization {
    id                      String                   @id @default(uuid())
    name                    String
    slug                    String
    logo                    String?
    metadata                String?
    isRecruiting            Boolean                  @default(false)
    createdAt               DateTime                 @default(now())
    Member                  Member[]
    Invitation              Invitation[]
    OrganizationRole        OrganizationRole[]
    recruitmentApplications RecruitmentApplication[]

    @@unique([slug])
    @@map("organization")
    @@schema("nexus")
}

model Member {
    id             String   @id @default(uuid())
    userId         String
    organizationId String
    role           String
    createdAt      DateTime @default(now())

    user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    @@map("member")
    @@schema("nexus")
}

model Invitation {
    id             String   @id @default(uuid())
    email          String
    inviterId      String
    organizationId String
    role           String
    status         String
    createdAt      DateTime @default(now())

    user         User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    @@map("invitation")
    @@schema("nexus")
}

model OrganizationRole {
    id             String       @id @default(uuid())
    organizationId String
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    role           String
    permission     String
    createdAt      DateTime     @default(now())
    updatedAt      DateTime?    @updatedAt

    @@map("organizationRole")
    @@schema("nexus")
}

model AuditLog {
    id             String   @id @default(uuid())
    userId         String? // Nullable for anonymous/failed auth
    action         String // e.g. "organization.delete"
    resource       String // e.g. "organization", "role"
    resourceId     String?
    organizationId String?
    status         String // "success", "error", "denied"
    errorMessage   String?
    changes        String? // JSON string representing the changes (Before/After)
    ipAddress      String?
    userAgent      String?
    metadata       String? // Additional metadata as JSON string
    createdAt      DateTime @default(now())

    user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([organizationId])
    @@index([action])
    @@index([createdAt])
    @@map("audit_log")
    @@schema("nexus")
}

model RecruitmentApplication {
    id                    String    @id @default(uuid())
    userId                String
    organizationId        String?
    rsiHandle             String
    age                   Int
    combatExperience      Int
    logisticsExperience   Int
    supportExperience     Int
    starCitizenExperience String?   @db.Text
    top3ShipsWhy          String    @db.Text
    whenStartPlayingSC    String    @db.Text
    whyJoin               String    @db.Text
    canCommitToDiscord    Boolean   @default(false)
    status                String    @default("pending") // pending, accepted, rejected
    appliedAt             DateTime  @default(now())
    reviewedAt            DateTime?
    reviewedBy            String?

    user         User          @relation("ApplicantUser", fields: [userId], references: [id], onDelete: Cascade)
    organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
    reviewer     User?         @relation("ReviewerUser", fields: [reviewedBy], references: [id], onDelete: SetNull)

    @@index([status, appliedAt])
    @@map("recruitment_application")
    @@schema("nexus")
}

model DiscordNotificationQueue {
    id              String    @id @default(uuid())
    eventType       String // e.g. "application_submitted", "application_reviewed"
    resourceId      String // e.g. RecruitmentApplication.id
    recipientUserId String // Discord ID of the recipient
    status          String    @default("pending") // pending, sent, failed
    attemptCount    Int       @default(0)
    lastAttemptAt   DateTime?
    sentAt          DateTime?
    errorMessage    String?
    payload         String? // JSON with notification data
    createdAt       DateTime  @default(now())

    @@index([status, createdAt])
    @@map("discord_notification_queue")
    @@schema("nexus")
}
