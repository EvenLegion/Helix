// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["arbiter", "nexus"]
}

model User {
  id                 String              @id
  username           String?
  nickname           String?
  name               String?
  email              String?
  emailVerified      Boolean?
  image              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  Merit              Merit[]
  nameChangeRequests NameChangeRequest[]
  accounts           Account[]
  sessions           Session[]

  @@map("user")
  @@schema("nexus")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
  @@schema("nexus")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
  @@schema("nexus")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
  @@schema("nexus")
}

model NameChangeRequest {
  id            Int      @id @default(autoincrement())
  userId        String
  currentName   String
  requestedName String
  reason        String
  denyReason    String?
  approved      Boolean  @default(false)
  approvedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("name_change_request")
  @@schema("arbiter")
}

model Merit {
  userID          String    @id @db.VarChar(19)
  merits          Int
  description     String    @db.VarChar(255)
  additionalNotes String    @db.VarChar(255)
  awardedBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  typeId          Int
  meritType       MeritType @relation(fields: [typeId], references: [id])
  user            User      @relation(fields: [userID], references: [id])

  @@map("merit")
  @@schema("arbiter")
}

model MeritType {
  id            Int            @id
  name          String         @db.VarChar(100)
  description   String         @db.VarChar(255)
  value         Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  merit         Merit[]
  eventSessions EventSession[]

  @@map("merit_type")
  @@schema("arbiter")
}

/// Event session within a guild voice channel
model EventSession {
  id            Int                       @id @default(autoincrement())
  /// If set, this session is part of a group whose root session has this id
  rootSessionId Int?
  /// Self-relation to group sessions under a single root
  root          EventSession?             @relation("EventSessionGroup", fields: [rootSessionId], references: [id])
  children      EventSession[]            @relation("EventSessionGroup")
  guildId       String
  channelId     String
  /// True if the voice/stage channel was created by the bot
  createdByBot  Boolean                   @default(false)
  startedBy     String
  startedAt     DateTime                  @default(now())
  endedAt       DateTime?
  status        String                    @default("ACTIVE") @db.VarChar(16)
  meritTypeId   Int?
  meritType     MeritType?                @relation(fields: [meritTypeId], references: [id])
  participants  EventSessionParticipant[]

  @@index([guildId, channelId, status])
  @@index([rootSessionId, status])
  @@map("event_session")
  @@schema("arbiter")
}

// Status values: ACTIVE | ENDED

/// Aggregate participation per user for an event session
model EventSessionParticipant {
  id                   Int          @id @default(autoincrement())
  eventSessionId       Int
  userId               String
  totalSecondsPresent  Int          @default(0)
  totalSecondsSpeaking Int          @default(0)
  lastJoinAt           DateTime?
  lastSpeakAt          DateTime?
  updatedAt            DateTime     @updatedAt
  session              EventSession @relation(fields: [eventSessionId], references: [id], onDelete: Cascade)

  @@unique([eventSessionId, userId])
  @@map("event_session_participant")
  @@schema("arbiter")
}

model Event {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  description String    @db.VarChar(255)
  eventDate   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  typeId      Int
  eventType   EventType @relation(fields: [typeId], references: [id])

  @@map("event")
  @@schema("arbiter")
}

model EventType {
  id          Int      @id
  name        String   @db.VarChar(100)
  description String   @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Event       Event[]

  @@map("event_type")
  @@schema("arbiter")
}
